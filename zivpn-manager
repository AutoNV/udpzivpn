    rm -f "${IP_LOCK_DIR}/${user}.lock"
    _ip_limit_log "MANUAL UNLOCK: $user oleh admin"
    echo -e "\033[1;32m✔ User $user berhasil di-unlock\033[0m"
  else
    echo "User $user tidak sedang dilock."
  fi
  _pause_back
}


  echo -e "${Y}  Cara mendapatkan Admin ID : chat @userinfobot di Telegram${N}"
  echo ""
  echo -e "${C}  Pilihan:${N}"
  echo -e "${W}  1) Set Token Bot & Admin ID baru${N}"
  echo -e "${W}  2) Test kirim notifikasi${N}"
  echo -e "${W}  3) Hapus konfigurasi${N}"

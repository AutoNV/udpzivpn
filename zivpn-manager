      # Sensor token — tampilkan 6 char pertama saja
      local masked_token="${cur_token:0:6}:***censored***"
      echo -e "${W}  Token saat ini : ${G}${masked_token}${N}"
    else
      echo -e "${W}  Token saat ini : ${R}Belum diset${N}"
    fi
    if [ -n "$cur_id" ]; then
      echo -e "${W}  Admin ID saat ini : ${G}${cur_id}${N}"

function _iplimit_show_locked() {
  clear
  local C='\033[0;36m' W='\033[1;37m' R='\033[0;31m' N='\033[0m'
  echo -e "${C}─── User yang Sedang LOCKED ───${N}"
  mkdir -p "$IP_LOCK_DIR"
  local found=0
  local now; now=$(date +%s)
  for lock_file in "${IP_LOCK_DIR}"/*.lock; do
    [ -f "$lock_file" ] || continue
    local user; user=$(basename "$lock_file" .lock)
    local lock_time; lock_time=$(cat "$lock_file")
    local elapsed=$(( now - lock_time ))
    local remaining=$(( 900 - elapsed ))
    [ "$remaining" -lt 0 ] && remaining=0
    printf "${R}%-20s${N} locked sejak %s | sisa: %ds\n" \
      "$user" "$(date -d "@$lock_time" '+%H:%M:%S')" "$remaining"
    found=1
  done
  [ "$found" -eq 0 ] && echo "Tidak ada user yang sedang dilock."
  echo ""
  _pause_back
}

function _iplimit_unlock_manual() {
  clear
  echo "─── Unlock User Manual ───"
  _iplimit_show_locked

function _create_account_logic() {
local password="$1"
local days="$2"
local db_file="/etc/zivpn/users.db"
if [ -z "$password" ] || [ -z "$days" ]; then
echo "Error: Password and days are required."
return 1
fi
if ! [[ "$days" =~ ^[0-9]+$ ]]; then
echo "Error: Invalid number of days."
return 1
fi
if grep -q "^${password}:" "$db_file"; then
echo "Error: Password '${password}' already exists."
return 1
fi
local expiry_date
expiry_date=$(date -d "+$days days" +%s | tr -d "\n\r")
echo "${password}:${expiry_date}" >> "$db_file"
jq --arg pass "$password" '.auth.config += [$pass]' /etc/zivpn/config.json > /etc/zivpn/config.json.tmp && mv /etc/zivpn/config.json.tmp /etc/zivpn/config.json
if [ $? -eq 0 ]; then
# Auto set IP limit = 1 untuk akun baru
_ip_limit_set_user "$password" "1"
mkdir -p "$IP_LOCK_DIR" "$IP_WARN_DIR"
restart_zivpn
local EXPIRE_FORMATTED
EXPIRE_FORMATTED=$(date -d "@$expiry_date" +"%d %B %Y %H:%M")
ip=$(cat /etc/zivpn/ip.txt)
isp=$(cat /etc/zivpn/isp.txt)
CERT_CN=$(openssl x509 -in /etc/zivpn/zivpn.crt -noout -subject | sed -n 's/.*CN = \([^,]*\).*/\1/p')
local host
if [ "$CERT_CN" == "zivpn" ]; then
host=$(cat /etc/zivpn/ip.txt)
else
host=$CERT_CN
fi
echo "Success:"
echo "DATA:host=$host"
echo "DATA:ip=$ip"
echo "DATA:isp=$isp"
echo "DATA:pass=$password"
echo "DATA:expire=$EXPIRE_FORMATTED"
local message=$(cat <<EOF
CREATE AKUN ZIVPN
Host     : $host
IP       : $ip
ISP      : $isp
Pass     : $password
Expire   : $EXPIRE_FORMATTED
IP Limit : 1 IP
EOF
)
send_telegram_notification "$message"
return 0
else
sed -i "/^${password}:/d" "$db_file"
echo "Error: Failed to update config.json."
return 1
fi
}

function create_manual_account() {
echo "───────── Create New Zivpn Account ───────"
read -p "Enter new password: " password
if [ -z "$password" ]; then
echo "Password cannot be empty."
return
fi
read -p "Enter active period (in days): " days
if ! [[ "$days" =~ ^[0-9]+$ ]]; then
echo "Invalid number of days."
return
fi
local result
result=$(_create_account_logic "$password" "$days")
if [[ "$result" == *"Success:"* ]]; then
local host ip isp expire
host=$(echo "$result" | grep "^DATA:host=" | cut -d= -f2)
ip=$(echo "$result" | grep "^DATA:ip=" | cut -d= -f2)
isp=$(echo "$result" | grep "^DATA:isp=" | cut -d= -f2)
expire=$(echo "$result" | grep "^DATA:expire=" | cut -d= -f2-)
echo ""
echo "─────── Account Created ───────"
echo "Host   : $host"
echo "IP     : $ip"
echo "ISP    : $isp"
echo "Pass   : $password"
echo "Expire : $expire"
echo "────────────────────────────────"
else
echo "$result"
fi
_pause_back
}

function _auto_fix_port() {
  clear
  local W='\033[1;37m'
  local G='\033[1;32m'
  local R='\033[0;31m'
  local C='\033[0;36m'
  local Y='\033[1;33m'
  local N='\033[0m'

  echo -e "${C}┌────────────────────────────────────────────┐"
  echo -e "${C}│${W}        🔧  Auto Fix Port API             ${C}│"
  echo -e "${C}└────────────────────────────────────────────┘${N}"
  echo ""

  local API_JS="/etc/zivpn/api/api.js"
  local CURRENT_PORT=""

  # Baca port saat ini
  if [ -f "$API_JS" ]; then
    CURRENT_PORT=$(grep -oP 'const PORT = \K[0-9]+' "$API_JS" 2>/dev/null)
  fi

  if [ -z "$CURRENT_PORT" ]; then
    _err "File api.js tidak ditemukan atau PORT tidak bisa dibaca!"
    echo -e "${Y}  Path: $API_JS${N}"
    echo ""
    _pause_back
    return
  fi

  echo -e "${C}  Port API saat ini : ${Y}${CURRENT_PORT}${N}"
  echo ""
  echo -e "${W}  Pilih port tujuan:${N}"
  echo -e "${C}  ──────────────────────────────────────────${N}"
  printf  "${C}  %2s. %-10s  ${W}%s${N}\n"  "1"  "Port 443"   "(HTTPS - paling jarang diblokir)"
  printf  "${C}  %2s. %-10s  ${W}%s${N}\n"  "2"  "Port 8443"  "(HTTPS alt - aman di kebanyakan hosting)"
  printf  "${C}  %2s. %-10s  ${W}%s${N}\n"  "3"  "Port 2053"  "(Cloudflare friendly)"
  printf  "${C}  %2s. %-10s  ${W}%s${N}\n"  "4"  "Port 2083"  "(Cloudflare friendly)"
  printf  "${C}  %2s. %-10s  ${W}%s${N}\n"  "5"  "Port 2087"  "(Cloudflare friendly)"
  printf  "${C}  %2s. %-10s  ${W}%s${N}\n"  "6"  "Custom"     "(Masukkan port sendiri)"
  echo -e "${C}  ──────────────────────────────────────────${N}"
  echo ""
  read -p "  Pilih (1-6): " port_choice

  local NEW_PORT=""
  case $port_choice in
    1) NEW_PORT=443  ;;
    2) NEW_PORT=8443 ;;
    3) NEW_PORT=2053 ;;
    4) NEW_PORT=2083 ;;
    5) NEW_PORT=2087 ;;
    6)
      read -p "  Masukkan port (1-65535): " NEW_PORT
      if ! [[ "$NEW_PORT" =~ ^[0-9]+$ ]] || [ "$NEW_PORT" -lt 1 ] || [ "$NEW_PORT" -gt 65535 ]; then
        _err "Port tidak valid!"
        _pause_back
        return
      fi
      ;;
    *)
      _warn "Pilihan tidak valid, kembali ke menu..."
      sleep 1
      /usr/bin/zivpn-manager
      return
      ;;
  esac

  if [ "$NEW_PORT" == "$CURRENT_PORT" ]; then
    _warn "Port sudah menggunakan ${NEW_PORT}, tidak perlu diubah."
    _pause_back
    return
  fi

  echo ""
  echo -e "${Y}  ⚡ Mengganti port ${CURRENT_PORT} → ${NEW_PORT} ...${N}"
  echo ""

  # 1. Update api.js
  _progress "Update api.js"
  sed -i "s/const PORT = ${CURRENT_PORT}/const PORT = ${NEW_PORT}/" "$API_JS"
  _ok "api.js diperbarui (PORT=${NEW_PORT})"

  # 2. Update iptables - hapus rule lama, tambah rule baru
  _progress "Update firewall iptables"
  iptables -D INPUT -p tcp --dport "${CURRENT_PORT}" -j ACCEPT 2>/dev/null
  iptables -I INPUT -p tcp --dport "${NEW_PORT}" -j ACCEPT
  _ok "Firewall: port ${CURRENT_PORT} ditutup, port ${NEW_PORT} dibuka"

  # 3. Simpan iptables (agar persist setelah reboot)
  if command -v iptables-save &>/dev/null; then
    iptables-save > /etc/iptables/rules.v4 2>/dev/null || true
  fi

  # 4. Restart API service
  _progress "Restart zivpn-api.service"
  systemctl restart zivpn-api.service
  sleep 2
  local svc_status
  svc_status=$(systemctl is-active zivpn-api.service 2>/dev/null)
  if [ "$svc_status" == "active" ]; then
    _ok "Service berjalan normal"
  else
    _err "Service gagal restart! Cek: journalctl -u zivpn-api.service -n 20"
  fi

  # 5. Tampilkan info
  local SERVER_IP
  SERVER_IP=$(cat /etc/zivpn/ip.txt 2>/dev/null || hostname -I | awk '{print $1}')
  local AUTH_KEY
  AUTH_KEY=$(cat /etc/zivpn/api_auth.key 2>/dev/null || echo "N/A")

  echo ""
  echo -e "${C}┌────────────────────────────────────────────┐"
  echo -e "${C}│${G}  ✅  Port API berhasil diganti!            ${C}│"
  echo -e "${C}├────────────────────────────────────────────┤"
  printf  "${C}│${W}  Port Lama  : ${R}%-28s${C}│\n" "${CURRENT_PORT}"
  printf  "${C}│${W}  Port Baru  : ${G}%-28s${C}│\n" "${NEW_PORT}"
  printf  "${C}│${W}  Test URL   : ${Y}http://${SERVER_IP}:${NEW_PORT}/create/zivpn${N}\n"
  printf  "${C}│${W}  Auth Key   : ${G}%-28s${C}│\n" "${AUTH_KEY}"
  echo -e "${C}└────────────────────────────────────────────┘${N}"
  echo ""
  echo -e "${Y}  ⚠  Jangan lupa update port di database panel (tabel zi_servers)!${N}"
  echo ""
  _pause_back
}


# ══════════════════════════════════════════════════════════
#  IP LIMIT MONITOR — lock 15 menit, banned jika repeat
# ══════════════════════════════════════════════════════════
IP_LIMIT_CONF="/etc/zivpn/ip_limit.conf"
IP_LOCK_DIR="/etc/zivpn/ip_locks"
IP_WARN_DIR="/etc/zivpn/ip_warns"
IP_LIMIT_LOG="/var/log/zivpn_ip_limit.log"
IP_LIMIT_TG_CONF="/etc/zivpn/ip_limit_telegram.conf"

# ── Kirim notifikasi khusus IP Limit (bot & admin tersendiri) ──
function _send_iplimit_telegram() {
  local message="$1"
  local BOT_TOKEN="" ADMIN_ID=""
  # Baca config IP limit telegram dulu
  if [ -f "$IP_LIMIT_TG_CONF" ]; then
    source "$IP_LIMIT_TG_CONF"
    BOT_TOKEN="${IPLIMIT_BOT_TOKEN:-}"
    ADMIN_ID="${IPLIMIT_ADMIN_ID:-}"
  fi
  # Fallback ke telegram.conf utama jika belum ada config khusus
  if [ -z "$BOT_TOKEN" ] || [ -z "$ADMIN_ID" ]; then
    if [ -f "$TELEGRAM_CONF" ]; then
      source "$TELEGRAM_CONF"
      BOT_TOKEN="${TELEGRAM_BOT_TOKEN:-}"
      ADMIN_ID="${TELEGRAM_CHAT_ID:-}"
    fi
  fi
  if [ -n "$BOT_TOKEN" ] && [ -n "$ADMIN_ID" ]; then
    curl -s -X POST "https://api.telegram.org/bot${BOT_TOKEN}/sendMessage" \
      -d "chat_id=${ADMIN_ID}" \
      --data-urlencode "text=${message}" \
      -d "parse_mode=Markdown" > /dev/null 2>&1
  fi
}

function _ip_limit_log() {
  echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> "$IP_LIMIT_LOG"
}

function _ip_limit_get_default() {
  if [ -f "$IP_LIMIT_CONF" ]; then
    local val; val=$(grep "^DEFAULT_IP_LIMIT=" "$IP_LIMIT_CONF" | cut -d= -f2 | tr -d ' ')
    [ -n "$val" ] && echo "$val" || echo "1"
  else
    echo "1"
  fi
}

function _ip_limit_get_user() {
  local user="$1"
  if [ -f "$IP_LIMIT_CONF" ]; then
    local val
    val=$(grep "^USER_LIMIT_${user}=" "$IP_LIMIT_CONF" 2>/dev/null | cut -d= -f2 | tr -d ' ')
    if [ -n "$val" ]; then
      echo "$val"
      return
    fi
  fi
  _ip_limit_get_default
}

function _ip_limit_set_user() {
  local user="$1"
  local limit="$2"
  mkdir -p /etc/zivpn
  touch "$IP_LIMIT_CONF"
  if grep -q "^USER_LIMIT_${user}=" "$IP_LIMIT_CONF"; then
    sed -i "s/^USER_LIMIT_${user}=.*/USER_LIMIT_${user}=${limit}/" "$IP_LIMIT_CONF"
  else
    echo "USER_LIMIT_${user}=${limit}" >> "$IP_LIMIT_CONF"
  fi
}

function _ip_limit_set_default_limit() {
  local limit="$1"
  mkdir -p /etc/zivpn
  touch "$IP_LIMIT_CONF"
  if grep -q "^DEFAULT_IP_LIMIT=" "$IP_LIMIT_CONF"; then
    sed -i "s/^DEFAULT_IP_LIMIT=.*/DEFAULT_IP_LIMIT=${limit}/" "$IP_LIMIT_CONF"
  else
    echo "DEFAULT_IP_LIMIT=${limit}" >> "$IP_LIMIT_CONF"
  fi
}

function _ip_limit_is_locked() {
  local user="$1"
  local lock_file="${IP_LOCK_DIR}/${user}.lock"
  [ -f "$lock_file" ] && return 0 || return 1
}

function _ip_limit_lock_user() {
  local user="$1"
  local active_ip_list="$2"
  mkdir -p "$IP_LOCK_DIR"
  echo "$(date +%s)" > "${IP_LOCK_DIR}/${user}.lock"
  _ip_limit_log "USER LOCKED: $user — lock 15 menit | IP aktif: $active_ip_list"
  local server_ip; server_ip=$(cat /etc/zivpn/ip.txt 2>/dev/null || echo "N/A")
  local limit; limit=$(_ip_limit_get_user "$user")
  local lock_until; lock_until=$(date -d "+15 minutes" '+%H:%M:%S')
  local msg="🔒 *AKUN DIKUNCI — IP LIMIT*

👤 User    : \`${user}\`
🚦 Limit   : ${limit} IP
🌐 IP Login: ${active_ip_list}
⏱ Kunci   : 15 menit (s/d ${lock_until})
🖥 Server  : ${server_ip}
📅 Waktu   : $(date '+%d-%m-%Y %H:%M:%S')

_Akun akan otomatis dibuka setelah 15 menit._
_Jika melanggar lagi → akun akan DIBANNED permanen._"
  _send_iplimit_telegram "$msg"
}

function _ip_limit_notify_multilogin() {
  local user="$1"
  local active_ip_list="$2"
  local count="$3"
  local limit="$4"
  local server_ip; server_ip=$(cat /etc/zivpn/ip.txt 2>/dev/null || echo "N/A")
  _ip_limit_log "MULTI LOGIN: $user — ${count} IP aktif (limit: ${limit}) | ${active_ip_list}"
  local msg="⚠️ *DETEKSI MULTI LOGIN*

👤 User     : \`${user}\`
🚦 Limit    : ${limit} IP
📊 IP Aktif : ${count} IP
🌐 IP List  :
${active_ip_list}
🖥 Server   : ${server_ip}
📅 Waktu    : $(date '+%d-%m-%Y %H:%M:%S')

_Akun sedang diproses untuk dikunci..._"
  _send_iplimit_telegram "$msg"
}

function _ip_limit_unlock_check() {
  mkdir -p "$IP_LOCK_DIR"
  local now; now=$(date +%s)
  for lock_file in "${IP_LOCK_DIR}"/*.lock; do
    [ -f "$lock_file" ] || continue
    local user; user=$(basename "$lock_file" .lock)
    local lock_time; lock_time=$(cat "$lock_file")
    local elapsed=$(( now - lock_time ))
    if [ "$elapsed" -ge 900 ]; then
      rm -f "$lock_file"
      _ip_limit_log "USER UNLOCKED: $user — otomatis setelah 15 menit"
      local server_ip; server_ip=$(cat /etc/zivpn/ip.txt 2>/dev/null || echo "N/A")
      local unlock_time; unlock_time=$(date '+%d-%m-%Y %H:%M:%S')
      local msg="✅ *AKUN DIBUKA KEMBALI*

👤 User    : \`${user}\`
🔓 Status  : Dikunci sudah > 15 menit, otomatis dibuka
🖥 Server  : ${server_ip}
📅 Waktu   : ${unlock_time}

_Peringatan: Jika melanggar lagi, akun akan DIBANNED permanen._"
      _send_iplimit_telegram "$msg"
    fi
  done
}

function _ip_limit_ban_user() {
  local user="$1"
  local reason="${2:-Melanggar IP limit ulang setelah dikunci}"
  _ip_limit_log "USER BANNED: $user — $reason"
  local server_ip; server_ip=$(cat /etc/zivpn/ip.txt 2>/dev/null || echo "N/A")
  local msg="🚫 *AKUN DIBANNED & DIHAPUS PERMANEN*

👤 User    : \`${user}\`
❌ Status  : BANNED PERMANEN
🖥 Server  : ${server_ip}
📅 Waktu   : $(date '+%d-%m-%Y %H:%M:%S')
📋 Alasan  : ${reason}

_Akun telah dihapus secara permanen dari sistem._"
  _send_iplimit_telegram "$msg"
  # Hapus akun permanen
  _delete_account_logic "$user" >/dev/null 2>&1
  # Hapus warn & lock
  rm -f "${IP_WARN_DIR}/${user}.warn" "${IP_LOCK_DIR}/${user}.lock"
}

function _ip_limit_check_user() {
  local user="$1"
  local limit; limit=$(_ip_limit_get_user "$user")
  mkdir -p "$IP_LOCK_DIR" "$IP_WARN_DIR"

  # Kumpulkan IP aktif dari log zivpn
  local ip_list=""
  local log_paths=("/var/log/zivpn.log" "/etc/zivpn/logs/access.log" "/var/log/zivpn_access.log")
  for lp in "${log_paths[@]}"; do
    if [ -f "$lp" ]; then
      ip_list=$(grep -i "$user" "$lp" 2>/dev/null \
        | grep -iE "connect|login|auth|session" \
        | grep -Eo '([0-9]{1,3}\.){3}[0-9]{1,3}' \
        | sort -u)
      break
    fi
  done

  local active_ips=0
  local ip_display="-"
  if [ -n "$ip_list" ]; then
    active_ips=$(echo "$ip_list" | wc -l)
    ip_display=$(echo "$ip_list" | tr '\n' ',' | sed 's/,$//')
  fi

  if [ "$active_ips" -gt "$limit" ]; then
    # Kirim notif multi login dulu
    _ip_limit_notify_multilogin "$user" "$ip_display" "$active_ips" "$limit"
    if _ip_limit_is_locked "$user"; then
      # Sudah pernah dilock, ini pelanggaran ke-2 → BAN
      _ip_limit_ban_user "$user" "Melanggar IP limit ulang setelah dikunci (${active_ips} IP, limit: ${limit})"
    else
      # Pertama kali → lock 15 menit
      _ip_limit_lock_user "$user" "$ip_display"
    fi
  fi
}

function _ip_limit_check_all() {
  # Baca semua user dari users.db dan cek tiap user
  local db_file="/etc/zivpn/users.db"
  [ -f "$db_file" ] || return
  while IFS=':' read -r password expiry_date; do
    [[ -z "$password" ]] && continue
    _ip_limit_check_user "$password"
  done < "$db_file"
  _ip_limit_unlock_check
}

function _ip_limit_get_active_ips_for_user() {
  # Coba baca dari log zivpn — sesuaikan path log jika berbeda
  local user="$1"
  local log_paths=("/var/log/zivpn.log" "/etc/zivpn/logs/access.log" "/var/log/zivpn_access.log")
  for lp in "${log_paths[@]}"; do
    if [ -f "$lp" ]; then
      grep -i "$user" "$lp" 2>/dev/null \
        | grep -iE "connect|login|auth|session" \
        | awk '{print $NF}' \
        | grep -Eo '([0-9]{1,3}\.){3}[0-9]{1,3}' \
        | sort -u
      return
    fi
  done
  echo ""
}

function show_ip_limit_menu() {
  local W='\033[1;37m'
  local G='\033[1;32m'
  local R='\033[0;31m'
  local C='\033[0;36m'
  local Y='\033[1;33m'
  local N='\033[0m'

  while true; do
    clear
    local default_limit; default_limit=$(_ip_limit_get_default)
    # Cek status bot
    local bot_status="${R}Belum diset${N}"
    if [ -f "$IP_LIMIT_TG_CONF" ]; then
      source "$IP_LIMIT_TG_CONF" 2>/dev/null
      if [ -n "${IPLIMIT_BOT_TOKEN:-}" ] && [ -n "${IPLIMIT_ADMIN_ID:-}" ]; then
        bot_status="${G}Aktif ✔${N}"
      fi
    fi
    echo -e "${C}┌────────────────────────────────────────────┐"
    echo -e "${C}│${W}      🛡️  IP Limit Monitor & Control       ${C}│"
    echo -e "${C}├────────────────────────────────────────────┤"
    printf  "${C}│${W}  Default IP Limit : ${G}%-24s${C}│\n" "$default_limit IP/user"
    printf  "${C}│${W}  Bot Notifikasi   : "; echo -ne "$bot_status"; printf "${C}%-s${N}\n" ""
    echo -e "${C}├────────────────────────────────────────────┤"
    printf  "${C}│${W}  %2s. %-38s${C}│\n" "1" "Lihat Status Login Semua User"
    printf  "${C}│${W}  %2s. %-38s${C}│\n" "2" "Set Default IP Limit (semua user)"
    printf  "${C}│${W}  %2s. %-38s${C}│\n" "3" "Set IP Limit per User"
    printf  "${C}│${W}  %2s. %-38s${C}│\n" "4" "Lihat User yang Sedang Dilock"
    printf  "${C}│${W}  %2s. %-38s${C}│\n" "5" "Unlock User Manual"
    printf  "${C}│${W}  %2s. %-38s${C}│\n" "6" "Ban/Hapus User Manual"
    printf  "${C}│${W}  %2s. %-38s${C}│\n" "7" "Lihat Log IP Limit"
    printf  "${C}│${W}  %2s. %-38s${C}│\n" "8" "Pasang/Hapus Cron Monitor"
    printf  "${C}│${W}  %2s. %-38s${C}│\n" "9" "⚙  Setup Token Bot & Admin ID"
    printf  "${C}│${W}  %2s. %-38s${C}│\n" "0" "Kembali ke Menu Utama"
    echo -e "${C}└────────────────────────────────────────────┘${N}"
    echo ""
    read -p " Pilih [0-9]: " choice

    case "$choice" in
    1) _iplimit_show_status ;;
    2) _iplimit_set_default ;;
    3) _iplimit_set_per_user ;;
    4) _iplimit_show_locked ;;
    5) _iplimit_unlock_manual ;;
    6) _iplimit_ban_manual ;;
    7) _iplimit_show_log ;;
    8) _iplimit_toggle_cron ;;
    9) _iplimit_setup_telegram ;;
    0) return ;;
    *) echo -e "${R}Pilihan tidak valid${N}"; sleep 1 ;;
    esac
  done
}

# ── Setup Token Bot & Admin ID khusus IP Limit ──────────
function _iplimit_setup_telegram() {
  local C='\033[0;36m' W='\033[1;37m' G='\033[1;32m' R='\033[0;31m' Y='\033[1;33m' N='\033[0m'
  clear

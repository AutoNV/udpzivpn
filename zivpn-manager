function _iplimit_toggle_cron() {
  clear
  echo "─── Pasang/Hapus Cron Monitor IP Limit ───"
  local cron_tag="# zivpn-ip-limit-monitor"
  if crontab -l 2>/dev/null | grep -q "$cron_tag"; then
    echo "Status: AKTIF"
    read -p "Hapus cron monitor? [y/N]: " c
    if [[ "$c" == "y" || "$c" == "Y" ]]; then
      (crontab -l 2>/dev/null | grep -v "$cron_tag") | crontab -
      echo -e "\033[1;32m✔ Cron monitor dihapus\033[0m"
    fi
  else
    echo "Status: TIDAK AKTIF"
    read -p "Pasang cron monitor (jalankan tiap 1 menit)? [y/N]: " c
    if [[ "$c" == "y" || "$c" == "Y" ]]; then
      # Buat script monitor standalone
      cat > /etc/zivpn/ip_limit_cron.sh << 'IPCRONEOF'
#!/bin/bash
/usr/bin/zivpn-manager ip_limit_check_all 2>/dev/null
IPCRONEOF
      chmod +x /etc/zivpn/ip_limit_cron.sh
      (crontab -l 2>/dev/null; echo "* * * * * /etc/zivpn/ip_limit_cron.sh $cron_tag") | crontab -
      echo -e "\033[1;32m✔ Cron monitor dipasang (setiap 1 menit)\033[0m"
    fi
  fi
  _pause_back
}


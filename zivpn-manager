    if [ -z "$new_id" ]; then echo -e "${R}Admin ID tidak boleh kosong${N}"; read -p "Enter..."; return; fi
    mkdir -p /etc/zivpn
    cat > "$IP_LIMIT_TG_CONF" << EOF
IPLIMIT_BOT_TOKEN=${new_token}
IPLIMIT_ADMIN_ID=${new_id}
EOF
    chmod 600 "$IP_LIMIT_TG_CONF"
    echo -e "${G}✔ Konfigurasi tersimpan!${N}"
    echo ""
    read -p "  Test kirim notifikasi sekarang? [y/N]: " do_test
    if [[ "$do_test" == "y" || "$do_test" == "Y" ]]; then
      local server_ip; server_ip=$(cat /etc/zivpn/ip.txt 2>/dev/null || echo "N/A")
      local test_msg="✅ *Test Notifikasi IP Limit*

Bot berhasil terhubung ke sistem IP Limit Monitor ZiVPN.

🖥 Server : ${server_ip}
📅 Waktu  : $(date '+%d-%m-%Y %H:%M:%S')

_Notifikasi akan dikirim untuk: Multi Login, Lock, Unlock, & Ban._"
      _send_iplimit_telegram "$test_msg"
      echo -e "${G}✔ Pesan test dikirim, cek Telegram Anda!${N}"
    fi
    ;;
  2)
    if [ ! -f "$IP_LIMIT_TG_CONF" ]; then
      echo -e "${R}Konfigurasi belum ada, set dulu (pilih 1)${N}"
      read -p "Enter..."; return
    fi
    local server_ip; server_ip=$(cat /etc/zivpn/ip.txt 2>/dev/null || echo "N/A")
    local test_msg="✅ *Test Notifikasi IP Limit*

Bot berhasil terhubung ke sistem IP Limit Monitor ZiVPN.

🖥 Server : ${server_ip}
📅 Waktu  : $(date '+%d-%m-%Y %H:%M:%S')

_Notifikasi akan dikirim untuk: Multi Login, Lock, Unlock, & Ban._"
    _send_iplimit_telegram "$test_msg"
